{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dev": "export NODE_ENV=development && concurrently --kill-others \"tsc -w\" \"nodemon dist/index.js\"",
    "start": "node ./dist/index.js",
    "migration:create": "NODE_ENV=development npx tsx node_modules/typeorm/cli.js migration:create",
    "migrate": "NODE_ENV=development npx tsx node_modules/typeorm/cli.js migration:run -d ./src/db/data-source.ts",
    "migrate:undo": "NODE_ENV=development npx tsx node_modules/typeorm/cli.js migration:revert -d ./src/db/data-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}